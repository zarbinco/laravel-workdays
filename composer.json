{
    "name": "zarbinco/laravel-workdays",
    "description": "Laravel-first workday and business-day calculation engine.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "workdays",
        "business-days",
        "holidays",
        "jalali",
        "hijri",
        "iran",
        "carbon"
    ],
    "support": {
        "issues": "https://github.com/zarbinco/laravel-workdays/issues",
        "source": "https://github.com/zarbinco/laravel-workdays"
    },
    "autoload": {
        "psr-4": {
            "Zarbinco\\LaravelWorkdays\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zarbinco\\LaravelWorkdays\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "hekmatinasser/verta": "^9.0",
        "islamic-network/calendar": "^1.21",
        "nesbot/carbon": "^2.72|^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zarbinco\\LaravelWorkdays\\WorkdaysServiceProvider"
            ],
            "aliases": {
                "Workday": "Zarbinco\\LaravelWorkdays\\Facades\\Workday"
            }
        }
    },
    "minimum-stability": "stable"
}
